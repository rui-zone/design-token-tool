---
source: tests/cli.rs
expression: render_output_files(&output_dir)
---
== foundation/spacing.tokens.json ==
{
  "spacing": {
    "xs": {
      "$type": "dimension",
      "$value": {
        "value": 4.0,
        "unit": "px"
      }
    },
    "sm": {
      "$type": "dimension",
      "$value": {
        "value": 8.0,
        "unit": "px"
      }
    },
    "columns": {
      "$type": "number",
      "$value": 12
    }
  }
}
== foundation/radius.tokens.json ==
{
  "radius": {
    "$type": "dimension",
    "sm": {
      "$value": {
        "value": 4.0,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 8.0,
        "unit": "px"
      }
    }
  }
}
== foundation/typography.tokens.json ==
{
  "typography": {
    "$type": "typography",
    "body-md": {
      "$value": {
        "fontFamily": "Public Sans",
        "fontSize": {
          "value": 16.0,
          "unit": "px"
        },
        "fontWeight": 400,
        "lineHeight": 1.6,
        "letterSpacing": {
          "value": 0.0,
          "unit": "px"
        }
      }
    }
  }
}
== foundation/colors.tokens.json ==
{
  "colors": {
    "$type": "color",
    "neutral-0": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1.0,
          1.0,
          1.0
        ],
        "alpha": 1.0,
        "hex": "#ffffff"
      }
    },
    "neutral-10": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.98,
          0.98,
          0.98
        ],
        "alpha": 1.0,
        "hex": "#fafafa"
      }
    },
    "black-alpha-20": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.0,
          0.0,
          0.0
        ],
        "alpha": 0.04,
        "hex": "#000000"
      }
    }
  }
}
== theme/light.tokens.json ==
{
  "colors": {
    "$type": "color",
    "background": {
      "$value": "{colors.neutral-10}"
    }
  }
}
== theme/dark.tokens.json ==
{
  "colors": {
    "$type": "color",
    "background": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.07,
          0.07,
          0.07
        ],
        "alpha": 1.0,
        "hex": "#111111"
      }
    }
  }
}
== tokens.resolver.json ==
{
  "$schema": "https://www.designtokens.org/schemas/2025.10/resolver.json",
  "name": "Test UI",
  "version": "2025.10",
  "description": "Fixture for DTCG conversion tests.",
  "sets": {
    "foundation": {
      "sources": [
        {
          "$ref": "foundation/spacing.tokens.json"
        },
        {
          "$ref": "foundation/radius.tokens.json"
        },
        {
          "$ref": "foundation/typography.tokens.json"
        },
        {
          "$ref": "foundation/colors.tokens.json"
        }
      ]
    }
  },
  "modifiers": {
    "theme": {
      "contexts": {
        "light": [
          {
            "$ref": "theme/light.tokens.json"
          }
        ],
        "dark": [
          {
            "$ref": "theme/dark.tokens.json"
          }
        ]
      },
      "default": "light"
    }
  },
  "resolutionOrder": [
    {
      "$ref": "#/sets/foundation"
    },
    {
      "$ref": "#/modifiers/theme"
    }
  ]
}
== theme.css ==
@custom-variant dark (&:where(.dark, .dark *, [data-theme="dark"], [data-theme="dark"] *));

@theme {
  --spacing-xs: 4px;
  --spacing-sm: 8px;
  --spacing-columns: 12;
  --radius-sm: 4px;
  --radius-md: 8px;
  --font-body_md: Public Sans;
  --text-body_md: 16px;
  --text-body_md--line-height: 1.6;
  --text-body_md--letter-spacing: 0px;
  --text-body_md--font-weight: normal;
  --color-neutral-0: #ffffff;
  --color-neutral-10: #fafafa;
  --color-black-alpha-20: rgb(0 0 0 / 0.04);
  --color-background: var(--color-neutral-10);
}

.dark,
[data-theme="dark"] {
  --color-background: #111111;
}
